# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Global / OS files
.DS_Store
Thumbs.db
*.log
*.tmp
*.temp

# IDEs and editors
.vscode/
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/

# Frontend (Angular / Node)
FrontEnd/node_modules/
FrontEnd/dist/
FrontEnd/.angular/
FrontEnd/.sass-cache/
FrontEnd/coverage/
FrontEnd/.nyc_output/
FrontEnd/npm-debug.log*
FrontEnd/yarn-debug.log*
FrontEnd/yarn-error.log*
FrontEnd/pnpm-debug.log*
FrontEnd/.env
FrontEnd/.env.*

# Backend (Python / FastAPI)
BackEnd/__pycache__/
BackEnd/**/*.py[cod]
BackEnd/.pytest_cache/
BackEnd/.mypy_cache/
BackEnd/.ruff_cache/
BackEnd/.coverage
BackEnd/htmlcov/
BackEnd/.venv/
BackEnd/venv/
BackEnd/env/
BackEnd/ENV/
BackEnd/.env
BackEnd/.env.*
BackEnd/*.sqlite3
BackEnd/*.db
BackEnd/*.pyo
BackEnd/*.pyd
BackEnd/.python-version
BackEnd/build/
BackEnd/dist/
BackEnd/*.egg-info/
BackEnd/.eggs/
BackEnd/pip-wheel-metadata/

# General Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

